#!/usr/bin/env node
const path = require("path");
const fs = require("fs");
const os = require("os");

const SCRIPTS = path.resolve(__dirname, "..", "scripts");
const cmd = process.argv[2];

// --help / -h / 无参数 → 打印帮助
if (!cmd || cmd === "--help" || cmd === "-h") {
  console.log(`stmem — Stone Memory 多线程记忆系统

用法:
  stmem status                                  查看所有线程状态
  stmem delete --thread <id> [--dry-run]        删除线程配置及数据
  stmem init --thread <id>                      初始化新线程
  stmem fork --parent <id> --thread <id>        将线程登记为共享父级记忆的子线程
  stmem feature-phrases [--thread <id>]         从所有清洗后的 features 提取通用检索词
  stmem feature-evidence [--thread <id>]        回查 archive 与 feelings 的词频证据
  stmem compress [--thread <id>] [--before 日期]  dry-run 压缩 daily feelings
  stmem compress --thread <id> --apply          写入 coarse_summary 并切换为 coarse
  stmem compact [--thread <id>]                 对低风险高收益周生成压缩 dry-run
  stmem compact --thread <id> --apply           原子压缩排名第一周的 coarse 候选
  stmem compact --thread <id> --from 日期 --to 日期 --apply  原子压缩精确日期窗口
  stmem hidden [--thread <id>] [--after-days N]  预览非核心 coarse 的长期沉寂候选
  stmem hidden --thread <id> --apply             将候选原子切换为 hidden
  stmem lifecycle [--thread <id>] [--action 类型]  feeling 生命周期只读报告
  stmem term-timeline --thread <id> --terms <词列表>  archive 曲线与 feeling 小点
  stmem import --source <json|jsonl|sqlite>       预览导入映射（加 --apply 写入）
  stmem import --dir <path> [--thread <id>]       递归预览目录中的对话数据
  stmem mine [--thread <id>] --all                  挖掘全部未处理日期，生成feelings + features
  stmem mine [--thread <id>] [--date <YYYY-MM-DD>]  挖掘单日 feelings + features
  stmem mine [--thread <id>] --date <日期> --force   直接重挖并覆盖当天结果
  stmem rebuild --thread <id> [--window N] [--tool-pairs N]  预览重建
  stmem rebuild --thread <id> --apply           实际写入
  stmem watcher [on|off]                        watcher 总开关启停
  stmem watcher archive [on|off]                watcher 自动挖掘对话开关
  stmem watcher miner [on|off]                  watcher 自动挖掘摘要+特征开关
  stmem db [status|migrate|migrate-all|export] [--thread <id>]  数据库管理

所有 --thread 可省略，默认取第一个已配置线程。

配置: ~/.stone_memory/stmem.json`);
  process.exit(0);
}

// 每次执行命令前确保 watcher 存活（init 自己会启动，跳过）
if (cmd !== "init") ensureWatcher();

switch (cmd) {
  case "init":
    require(path.join(SCRIPTS, "stmem-init"));
    break;
  case "fork":
    require(path.join(SCRIPTS, "stmem-fork"));
    break;
  case "feature-phrases":
    require(path.join(SCRIPTS, "stmem-feature-phrases"));
    break;
  case "feature-evidence":
    require(path.join(SCRIPTS, "stmem-feature-evidence"));
    break;
  case "compress":
    require(path.join(SCRIPTS, "stmem-compress"));
    break;
  case "compact":
    require(path.join(SCRIPTS, "stmem-compact"));
    break;
  case "hidden":
    require(path.join(SCRIPTS, "stmem-hidden"));
    break;
  case "lifecycle":
    require(path.join(SCRIPTS, "stmem-lifecycle"));
    break;
  case "term-timeline":
    require(path.join(SCRIPTS, "stmem-term-timeline"));
    break;
  case "mine":
    require(path.join(SCRIPTS, "stmem-mine"));
    break;
  case "rebuild":
    require(path.join(SCRIPTS, "stmem-rebuild"));
    break;
  case "status":
    require(path.join(SCRIPTS, "stmem-status"));
    break;
  case "list":
    require(path.join(SCRIPTS, "stmem-list"));
    break;
  case "delete":
    require(path.join(SCRIPTS, "stmem-delete"));
    break;
  case "sync":
    require(path.join(SCRIPTS, "stmem-sync"));
    break;
  case "import":
    require(path.join(SCRIPTS, "stmem-import"));
    break;
  case "adapt":
    require(path.join(SCRIPTS, "stmem-adapt"));
    break;
  case "watcher":
    require(path.join(SCRIPTS, "stmem-watcher"));
    break;
  case "db":
    require(path.join(SCRIPTS, "stmem-db"));
    break;
  default:
    console.log("未知命令: " + cmd + "\n运行 stmem --help 查看可用命令");
    process.exit(1);
}

function ensureWatcher() {
  const { spawn } = require("child_process");
  const pidFile = path.join(os.homedir(), ".stone_memory", "watcher.pid");
  const watcherScript = path.join(SCRIPTS, "watcher-supervisor.js");

  if (!fs.existsSync(watcherScript)) return;

  try {
    const oldPid = parseInt(fs.readFileSync(pidFile, "utf8"), 10);
    try { process.kill(oldPid, 0); return; } catch {}
  } catch {}

  // watcher 不在运行，自动拉起
  const w = spawn(process.execPath, [watcherScript], {
    detached: true,
    stdio: ["ignore", "ignore", "ignore"],
  });
  w.unref();
  fs.writeFileSync(pidFile, String(w.pid));
  // 不打印——后台静默启动
}
